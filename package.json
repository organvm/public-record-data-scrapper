{
  "name": "spark-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm --workspace apps/web run dev",
    "dev:server": "tsx --watch server/index.ts",
    "dev:worker": "tsx --watch server/worker.ts",
    "dev:full": "concurrently -n web,api,worker -c blue,green,yellow \"npm run dev\" \"npm run dev:server\" \"npm run dev:worker\"",
    "dev:mobile": "npm --workspace apps/mobile run start",
    "dev:desktop": "npm --workspace apps/desktop run dev",
    "seed": "tsx scripts/seed-database.ts",
    "kill": "fuser -k 5000/tcp",
    "build": "npm --workspace apps/web run build",
    "build:server": "node scripts/build-server.mjs",
    "build:render": "npm run build && npm run build:server",
    "build:all": "npm run build && npm run build:server",
    "build:desktop": "npm --workspace apps/desktop run build",
    "start": "node dist/server.cjs",
    "start:worker": "node --import tsx server/worker.ts",
    "lint": "eslint .",
    "optimize": "vite optimize --config apps/web/vite.config.ts",
    "preview": "npm --workspace apps/web run preview",
    "test": "npm --workspace apps/web run test",
    "test:watch": "npm --workspace apps/web run test:watch",
    "test:ui": "npm --workspace apps/web run test:ui",
    "test:coverage": "npm --workspace apps/web run test:coverage",
    "test:server": "vitest --config vitest.config.server.ts",
    "test:server:strict": "ENFORCE_COVERAGE=true vitest --config vitest.config.server.ts",
    "test:server:coverage": "vitest --config vitest.config.server.ts --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:scrapers": "tsx scripts/scrapers/test-scrapers.ts",
    "test:scrapers:tx": "tsx scripts/scrapers/test-scrapers.ts TX",
    "test:scrapers:fl": "tsx scripts/scrapers/test-scrapers.ts FL",
    "test:scrapers:ca": "tsx scripts/scrapers/test-scrapers.ts CA",
    "test:scrapers:ny": "tsx scripts/scrapers/test-scrapers.ts NY",
    "test:scrapers:headed": "tsx scripts/scrapers/test-scrapers.ts --headed",
    "postinstall": "node ./scripts/ensure-main-branch.mjs",
    "scrape": "tsx scripts/cli-scraper.ts",
    "scrape:scheduled": "tsx scripts/scheduled-run.ts",
    "migrate": "npm run db:migrate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:test": "tsx scripts/db-test.ts",
    "db:test:start": "scripts/test-db.sh start",
    "db:test:stop": "scripts/test-db.sh stop",
    "db:test:status": "scripts/test-db.sh status",
    "db:test:reset": "scripts/test-db.sh reset",
    "video:generate": "bash scripts/video-production/generate-videos.sh",
    "video:validate": "npx tsx scripts/video-production/validate.ts",
    "video:help": "bash scripts/video-production/generate-videos.sh --help",
    "prepare": "husky",
    "share": "lt --port 5000"
  },
  "dependencies": {
    "@github/spark": "^0.44.5",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@octokit/core": "^7.0.6",
    "@phosphor-icons/react": "^2.1.7",
    "@radix-ui/colors": "^3.0.0",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.3",
    "@radix-ui/react-context-menu": "^2.2.6",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-hover-card": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-navigation-menu": "^1.2.5",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toggle": "^1.1.2",
    "@radix-ui/react-toggle-group": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/vite": "^4.1.11",
    "@tanstack/react-query": "^5.90.20",
    "@types/dompurify": "^3.2.0",
    "bullmq": "^5.67.1",
    "chalk": "^5.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "commander": "^14.0.2",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "d3": "^7.9.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.11",
    "dotenv": "^17.2.3",
    "embla-carousel-react": "^8.5.2",
    "express": "^5.2.1",
    "framer-motion": "^12.6.2",
    "helmet": "^8.1.0",
    "input-otp": "^1.4.2",
    "ioredis": "^5.9.2",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.562.0",
    "marked": "^17.0.1",
    "next-themes": "^0.4.6",
    "octokit": "^5.0.5",
    "ora": "^8.1.1",
    "pg": "^8.16.3",
    "puppeteer": "^24.31.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^19.0.0",
    "react-day-picker": "^9.12.0",
    "react-dom": "^19.2.0",
    "react-error-boundary": "^6.0.0",
    "react-hook-form": "^7.69.0",
    "react-is": "^19.2.3",
    "react-resizable-panels": "^4.0.15",
    "recharts": "^3.6.0",
    "sonner": "^2.0.1",
    "stripe": "^18.5.0",
    "swagger-ui-express": "^5.0.1",
    "tailwind-merge": "^3.0.2",
    "three": "^0.182.0",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.2.4",
    "uuid": "^14.0.0",
    "vaul": "^1.1.2",
    "yamljs": "^0.3.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.49.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.2",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/yamljs": "^0.2.34",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitejs/plugin-react-swc": "^4.2.1",
    "@vitest/coverage-v8": "^4.0.8",
    "@vitest/ui": "^4.0.8",
    "axios": "^1.15.2",
    "cheerio": "^1.1.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "localtunnel": "^2.0.2",
    "prettier": "^3.6.2",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.49.0",
    "vite": "^7.3.2",
    "vitest": "^4.0.16"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "localtunnel": {
      "axios": "^1.7.4"
    }
  }
}
